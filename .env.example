# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_anon_key

# Admin
VITE_ADMIN_EMAIL=your_admin_email
VITE_ADMIN_PASSWORD=your_admin_password

# Cron
# Used to protect the manual-only /api/studypulse/cron-trigger endpoint and the
# /api/studypulse/health endpoint.  Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Also add SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY as GitHub repository secrets
# (Settings → Secrets → Actions) so the GitHub Actions workflow can call the cron.
CRON_SECRET=your_cron_secret
